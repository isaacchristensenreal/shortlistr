# ─────────────────────────────────────────────────────────
# VERCEL — paste these two values into:
#   Vercel Dashboard → Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────

VITE_SUPABASE_URL=https://tnrspoxrqejmqxyblgcw.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─────────────────────────────────────────────────────────
# SUPABASE EDGE FUNCTION SECRETS — set these in:
#   Supabase Dashboard → Project → Edge Functions → Secrets
#   (NOT in Vercel — these live in Supabase only)
# ─────────────────────────────────────────────────────────

# Already working (set this first):
OPENAI_API_KEY=sk-...

# Add these AFTER the site is live on Vercel:
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRO_PRICE_ID=price_...
SITE_URL=https://your-vercel-domain.vercel.app

# STRIPE_WEBHOOK_SECRET — get this from Stripe Dashboard after setting up the webhook:
#   Stripe Dashboard → Developers → Webhooks → Add endpoint
#   Endpoint URL: https://<your-supabase-project>.supabase.co/functions/v1/stripe-webhook
#   Events to listen for: checkout.session.completed, customer.subscription.deleted
#   Then copy the "Signing secret" (whsec_...) here:
STRIPE_WEBHOOK_SECRET=whsec_...
